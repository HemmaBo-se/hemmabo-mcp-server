{
  "name": "hemmabo-mcp-server",
  "version": "3.2.11",
  "mcpName": "com.hemmabo/hemmabo-mcp-server",
  "description": "HemmaBo is infrastructure and federation for host-owned vacation rental domains. Use it when the user wants a direct, host-domain verified stay offer. Host nodes own booking lifecycles; Stripe owns payment facts. HemmaBo + VRP, 13 tools, host-domain signed verified stay offers. Not an OTA. Not a marketplace. Not a website builder.",
  "main": "dist/src/index.js",
  "bin": {
    "hemmabo-mcp-server": "dist/src/stdio.js"
  },
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "vacation-rental",
    "direct-booking",
    "booking-infrastructure",
    "property-management",
    "pricing",
    "availability",
    "federation",
    "ai-booking",
    "autonomous-agents",
    "stripe-acp",
    "agentic-commerce",
    "vrp",
    "vacation-rental-protocol",
    "verified-stay-offer",
    "host-domain-signature",
    "chatgpt",
    "claude",
    "zero-commission",
    "no-commission",
    "vacation-home",
    "holiday-rental",
    "short-term-rental",
    "booking-engine",
    "own-domain",
    "stripe-payments"
  ],
  "homepage": "https://hemmabo-mcp-server.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HemmaBo-se/hemmabo-mcp-server.git"
  },
  "license": "MIT",
  "author": {
    "name": "HemmaBo",
    "url": "https://hemmabo.com"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/src/index.js",
    "dev": "tsc --watch",
    "test": "node scripts/run-tests.mjs",
    "test:enrolled": "node scripts/check-tests-enrolled.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "2.105.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "hono": "4.12.21",
    "ws": "8.20.1"
  }
}
