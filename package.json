{
  "name": "hemmabo-mcp-server",
  "version": "3.1.4",
  "description": "World's first vacation rental MCP server. Enable AI agents (ChatGPT, Claude, Gemini) to search, book, and manage vacation rental reservations. 9 production tools: search, availability, pricing, booking, checkout (Stripe ACP), cancellation, rescheduling. Zero commission. Live at villaåkerlyckan.se.",
  "main": "dist/index.js",
  "bin": {
    "hemmabo-mcp-server": "dist/stdio.js"
  },
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "vacation-rental",
    "direct-booking",
    "property-management",
    "pricing",
    "availability",
    "federation",
    "ai-booking",
    "autonomous-agents",
    "stripe-acp",
    "agentic-commerce",
    "chatgpt",
    "claude",
    "zero-commission",
    "vacation-home",
    "holiday-rental",
    "airbnb-alternative"
  ],
  "homepage": "https://hemmabo-mcp-server.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/HemmaBo-se/hemmabo-mcp-server"
  },
  "license": "MIT",
  "author": {
    "name": "HemmaBo",
    "url": "https://hemmabo.se"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.49.0",
    "express": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.3",
    "@vercel/node": "^5.7.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
