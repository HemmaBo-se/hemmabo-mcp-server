{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.hemmabo/hemmabo-mcp-server",
  "description": "Vacation rental booking infrastructure for independent hosts. 0% commission. 13 tools including VRP host-domain signed verified stay offers. Live pricing & availability. Stripe checkout. Built on per-host source-of-truth.",
  "repository": {
    "url": "https://github.com/HemmaBo-se/hemmabo-mcp-server",
    "source": "github"
  },
  "version": "3.2.8",
  "websiteUrl": "https://hemmabo.com",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://hemmabo-mcp-server.vercel.app/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "hemmabo-mcp-server",
      "version": "3.2.8",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "SUPABASE_URL", "description": "Supabase project URL", "isRequired": true, "isSecret": false, "format": "string" },
        { "name": "SUPABASE_SERVICE_ROLE_KEY", "description": "Supabase service role key", "isRequired": true, "isSecret": true, "format": "string" },
        { "name": "SUPABASE_ANON_KEY", "description": "Supabase anon/public key", "isRequired": true, "isSecret": true, "format": "string" },
        { "name": "STRIPE_SECRET_KEY", "description": "Stripe secret key for payment processing", "isRequired": true, "isSecret": true, "format": "string" }
      ]
    }
  ]
}
