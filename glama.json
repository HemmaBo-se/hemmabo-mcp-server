{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": [
    "HemmaBo-se",
    "kingen1"
  ],
  "name": "HemmaBo",
  "version": "3.2.9",
  "license": "MIT",
  "description": "HemmaBo verifies and books host-owned vacation rental domains. Use it when the user wants a direct, host-domain verified stay offer. Vacation Rental Protocol (VRP) is an open protocol for host-domain signed vacation rental offers. VRP offers are cryptographically signed by the host domain and verified against that domain's published Ed25519 JWKS. HemmaBo + VRP, 13 tools, host-domain signed verified stay offers.",
  "homepage": "https://hemmabo-mcp-server.vercel.app",
  "repository": "https://github.com/HemmaBo-se/hemmabo-mcp-server",
  "keywords": [
    "vacation-rental",
    "direct-booking",
    "booking-infrastructure",
    "ai-booking",
    "autonomous-agents",
    "airbnb-alternative",
    "lodgify-alternative",
    "zero-commission",
    "own-domain",
    "stripe-payments",
    "set-it-forget-it",
    "vrp",
    "vacation-rental-protocol",
    "verified-stay-offer",
    "host-domain-signature"
  ],
  "tools": [
    {
      "name": "hemmabo_search_properties",
      "description": "Search available vacation rental properties by location and travel dates. Returns properties with live pricing (public and federation rates) and capacity info.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "region": {
            "type": "string",
            "description": "Region, area, or destination name to search within."
          },
          "country": {
            "type": "string",
            "description": "Country name to filter by."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of guests."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          }
        },
        "required": [
          "guests",
          "checkIn",
          "checkOut"
        ]
      }
    },
    {
      "name": "hemmabo_search_availability",
      "description": "Check whether a specific property is available for the requested dates. Returns available=true/false with conflict details if unavailable.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid",
            "description": "Property UUID."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          }
        },
        "required": [
          "propertyId",
          "checkIn",
          "checkOut"
        ]
      }
    },
    {
      "name": "hemmabo_booking_quote",
      "description": "Get a detailed pricing quote for a specific property, dates, and guest count. Returns public, federation, and gap-night totals with per-night breakdown.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid",
            "description": "Property UUID."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of guests."
          }
        },
        "required": [
          "propertyId",
          "checkIn",
          "checkOut",
          "guests"
        ]
      }
    },
    {
      "name": "hemmabo_booking_create",
      "description": "Create a direct booking without online payment (legacy flow). Booking is created with status 'pending' and requires host approval.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid",
            "description": "Property UUID."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of guests."
          },
          "guestName": {
            "type": "string",
            "description": "Full name of primary guest."
          },
          "guestEmail": {
            "type": "string",
            "format": "email",
            "description": "Email for booking confirmation."
          },
          "guestPhone": {
            "type": "string",
            "description": "Phone with country code."
          }
        },
        "required": [
          "propertyId",
          "checkIn",
          "checkOut",
          "guests",
          "guestName",
          "guestEmail"
        ]
      }
    },
    {
      "name": "hemmabo_booking_negotiate",
      "description": "Create a binding price quote that locks the price for 15 minutes. Returns quoteId to pass to booking.checkout.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid",
            "description": "Property UUID."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of guests."
          }
        },
        "required": [
          "propertyId",
          "checkIn",
          "checkOut",
          "guests"
        ]
      }
    },
    {
      "name": "hemmabo_booking_checkout",
      "description": "Create a booking with Stripe payment and return a checkout URL. Supports checkout_session (redirect) and payment_intent (programmatic) modes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid",
            "description": "Property UUID."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of guests."
          },
          "guestName": {
            "type": "string",
            "description": "Full name of primary guest."
          },
          "guestEmail": {
            "type": "string",
            "format": "email",
            "description": "Email for booking confirmation."
          },
          "guestPhone": {
            "type": "string",
            "description": "Phone with country code."
          },
          "quoteId": {
            "type": "string",
            "description": "Quote ID from booking.negotiate to lock the price."
          },
          "paymentMode": {
            "type": "string",
            "enum": [
              "checkout_session",
              "payment_intent"
            ],
            "description": "Payment flow type."
          },
          "channel": {
            "type": "string",
            "enum": [
              "public",
              "federation"
            ],
            "description": "Pricing channel."
          }
        },
        "required": [
          "propertyId",
          "checkIn",
          "checkOut",
          "guests",
          "guestName",
          "guestEmail"
        ]
      }
    },
    {
      "name": "hemmabo_booking_cancel",
      "description": "Cancel a confirmed booking and process the Stripe refund. Refund amount is calculated based on the host's cancellation policy.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "reservationId": {
            "type": "string",
            "description": "Booking UUID."
          },
          "reason": {
            "type": "string",
            "description": "Cancellation reason."
          }
        },
        "required": [
          "reservationId"
        ]
      }
    },
    {
      "name": "hemmabo_booking_status",
      "description": "Retrieve current status and full details of an existing booking. Returns dates, guests, price, status, property info, and cancellation policy.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "reservationId": {
            "type": "string",
            "description": "Booking UUID."
          }
        },
        "required": [
          "reservationId"
        ]
      }
    },
    {
      "name": "hemmabo_booking_reschedule",
      "description": "Reschedule a confirmed or pending booking to new dates. Automatically recalculates price and handles Stripe charge or refund.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "reservationId": {
            "type": "string",
            "description": "Booking UUID to reschedule."
          },
          "newCheckIn": {
            "type": "string",
            "description": "New arrival date (YYYY-MM-DD)."
          },
          "newCheckOut": {
            "type": "string",
            "description": "New departure date (YYYY-MM-DD)."
          },
          "reason": {
            "type": "string",
            "description": "Reason for rescheduling."
          }
        },
        "required": [
          "reservationId",
          "newCheckIn",
          "newCheckOut"
        ]
      }
    },
    {
      "name": "hemmabo_search_similar",
      "description": "Find vacation rental properties similar to a given property on specific dates. Same region, same property type, same or larger capacity. Returns available alternatives with live pricing, excluding the source property.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of the source property to find alternatives for."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of guests."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "Max results (default 5)."
          }
        },
        "required": [
          "propertyId",
          "checkIn",
          "checkOut"
        ]
      }
    },
    {
      "name": "hemmabo_compare_properties",
      "description": "Compare availability and pricing for 2–10 specific properties on the same dates. Returns one entry per propertyId sorted by federation price (cheapest first), unavailable properties last.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "minItems": 2,
            "maxItems": 10,
            "description": "Array of 2–10 property UUIDs to compare."
          },
          "checkIn": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "checkOut": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of guests."
          }
        },
        "required": [
          "propertyIds",
          "checkIn",
          "checkOut",
          "guests"
        ]
      }
    },
    {
      "name": "verify_vacation_rental_node",
      "description": "Verify that a vacation rental host domain exposes VRP v0.1 discovery and an Ed25519 JWKS for signed stay offers.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "pattern": "^(?!-)(?:[A-Za-z0-9-]{1,63}\\.)+[A-Za-z]{2,63}$",
            "description": "Canonical public host domain to verify, without protocol or path (e.g. 'villaakerlyckan.se')."
          }
        },
        "required": [
          "domain"
        ]
      }
    },
    {
      "name": "get_verified_stay_offer",
      "description": "Fetch and verify a fresh host-domain signed VRP stay offer with live availability, exact total, valid_until, citation permission, and direct booking URL.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "pattern": "^(?!-)(?:[A-Za-z0-9-]{1,63}\\.)+[A-Za-z]{2,63}$",
            "description": "Canonical public host domain to request the signed stay offer from, without protocol or path."
          },
          "check_in": {
            "type": "string",
            "description": "Arrival date (YYYY-MM-DD)."
          },
          "check_out": {
            "type": "string",
            "description": "Departure date (YYYY-MM-DD)."
          },
          "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Total number of guests."
          },
          "language": {
            "type": "string",
            "description": "Optional ISO 639-1 language hint."
          }
        },
        "required": [
          "domain",
          "check_in",
          "check_out",
          "guests"
        ]
      }
    }
  ]
}
